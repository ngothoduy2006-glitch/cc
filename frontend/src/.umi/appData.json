      "__absFile": "C:/Users/Vu Duy Khanh/BTL-WEB-main/frontend/src/pages/auth/login.tsx"
    },
    "3": {
      "path": "/auth/register",
      "file": "@/pages/auth/register.tsx",
      "parentId": "1",
