      "absPath": "/profile/:id",
      "__content": "import React, { useEffect, useState } from 'react';\nimport { useParams } from '@umijs/max';\nimport { motion } from 'framer-motion';\nimport { UserOutlined, CalendarOutlined } from '@ant-design/icons';\nimport { adminUsersAPI, postsAPI } from '@/services/api';\nimport type { User, Post } from '@/types';\nimport PostCard from '@/components/PostCard';\nimport { PostCardSkeleton } from '@/components/LoadingSkeleton';\nimport dayjs from 'dayjs';\n\nconst roleMap: Record<string, { label: string; color: string }> = {\n  student:  { label: 'Sinh viên', color: '#4F8CFF' },\n  lecturer: { label: 'Giảng viên', color: '#7B61FF' },\n  admin:    { label: 'Admin',     color: '#FF6B6B' },\n};\n\nexport default function ProfilePage() {\n  const { id } = useParams<{ id: string }>();\n  const [user, setUser] = useState<User | null>(null);\n  const [posts, setPosts] = useState<Post[]>([]);\n  const [loading, setLoading] = useState(true);\n\n  useEffect(() => {\n    if (!id) return;\n    setLoading(true);\n    Promise.all([\n      adminUsersAPI.getUserById(id).then((r) => r.data),\n      postsAPI.getPosts({ limit: 20 }).then((r) => (r.data as any)?.data || []),\n    ])\n      .then(([userData, postsData]) => {\n        setUser(userData as User);\n        setPosts((postsData as Post[]).filter((p) => p.authorId === id));\n      })\n      .catch(() => {})\n      .finally(() => setLoading(false));\n  }, [id]);\n\n  if (loading) {\n    return (\n      <div className=\"max-w-4xl mx-auto px-4 py-8 space-y-4\">\n        <div className=\"skeleton h-40 w-full rounded-3xl\" />\n        {Array.from({ length: 3 }).map((_, i) => <PostCardSkeleton key={i} />)}\n      </div>\n    );\n  }\n\n  if (!user) return (\n    <div className=\"text-center py-20\" style={{ color: 'var(--text-muted)' }}>Không tìm thấy người dùng</div>\n  );\n\n  const role = roleMap[user.role] || roleMap.student;\n\n  return (\n    <div className=\"max-w-4xl mx-auto px-4 sm:px-6 py-8\">\n      {/* Profile header */}\n      <motion.div\n        className=\"rounded-3xl p-8 border mb-8\"\n        style={{ background: 'var(--surface)', borderColor: 'var(--border)' }}\n        initial={{ opacity: 0, y: 20 }}\n        animate={{ opacity: 1, y: 0 }}\n      >\n        <div className=\"flex flex-col sm:flex-row gap-6 items-start sm:items-center\">\n          {/* Avatar */}\n          <div\n            className=\"w-20 h-20 rounded-2xl flex items-center justify-center text-white text-3xl font-black flex-shrink-0\"\n            style={{ background: `linear-gradient(135deg, ${role.color}, ${role.color}88)` }}\n          >\n            {user.name.charAt(0)}\n          </div>\n\n          <div className=\"flex-1\">\n            <div className=\"flex items-center gap-3 flex-wrap mb-2\">\n              <h1 className=\"text-2xl font-black\" style={{ color: 'var(--text)' }}>{user.name}</h1>\n              <span\n                className=\"px-3 py-1 rounded-full text-xs font-bold text-white\"\n                style={{ background: role.color }}\n              >\n                {role.label}\n              </span>\n              {user.code && (\n                <span className=\"text-sm\" style={{ color: 'var(--text-muted)' }}>{user.code}</span>\n              )}\n            </div>\n\n            {user.bio && (\n              <p className=\"text-sm mb-3\" style={{ color: 'var(--text-muted)' }}>{user.bio}</p>\n            )}\n\n            <div className=\"flex flex-wrap gap-4 text-xs\" style={{ color: 'var(--text-muted)' }}>\n              {user.faculty && <span>🏫 {user.faculty}</span>}\n              {user.department && <span>📚 {user.department}</span>}\n              {user.class && <span>🎓 {user.class}</span>}\n              <span className=\"flex items-center gap-1\">\n                <CalendarOutlined /> Tham gia {dayjs(user.createdAt).format('MM/YYYY')}\n              </span>\n            </div>\n          </div>\n\n          {/* Stats */}\n          <div className=\"flex gap-6\">\n            {[\n              { label: 'Bài đăng', value: posts.length },\n              { label: 'Votes', value: posts.reduce((sum, p) => sum + p.votes, 0) },\n            ].map((s) => (\n              <div key={s.label} className=\"text-center\">\n                <p className=\"text-2xl font-black text-gradient\">{s.value}</p>\n                <p className=\"text-xs\" style={{ color: 'var(--text-muted)' }}>{s.label}</p>\n              </div>\n            ))}\n          </div>\n        </div>\n      </motion.div>\n\n      {/* Posts */}\n      <h2 className=\"font-bold text-lg mb-4\" style={{ color: 'var(--text)' }}>\n        Câu hỏi đã đăng ({posts.length})\n      </h2>\n      <div className=\"space-y-4\">\n        {posts.length === 0 ? (\n          <div className=\"text-center py-12 rounded-2xl border\" style={{ background: 'var(--surface)', borderColor: 'var(--border)' }}>\n            <p style={{ color: 'var(--text-muted)' }}>Chưa có câu hỏi nào</p>\n          </div>\n        ) : posts.map((p, i) => <PostCard key={p.id} post={p} index={i} />)}\n      </div>\n    </div>\n  );\n}\n",
      "__isJSFile": true,
      "__absFile": "C:/Users/Vu Duy Khanh/BTL-WEB-main/frontend/src/pages/profile/detail.tsx"
    },
    "17": {
      "path": "/saved-posts",
      "file": "@/pages/saved-posts.tsx",
      "parentId": "10",
      "id": "17",
      "absPath": "/saved-posts",
      "__content": "import React, { useEffect, useState } from 'react';\nimport { motion } from 'framer-motion';\nimport { BookmarkFilled, LoadingOutlined } from '@ant-design/icons';\nimport { postsAPI } from '@/services/api';\nimport type { Post } from '@/types';\nimport PostCard from '@/components/PostCard';\nimport { PostCardSkeleton } from '@/components/LoadingSkeleton';\nimport { useAuthStore } from '@/stores/auth';\nimport { history } from '@umijs/max';\n\nexport default function SavedPostsPage() {\n  const { isAuthenticated } = useAuthStore();\n  const [posts, setPosts] = useState<Post[]>([]);\n  const [loading, setLoading] = useState(true);\n\n  useEffect(() => {\n    if (!isAuthenticated) {\n      history.push('/auth/login');\n      return;\n    }\n    postsAPI.getSavedPosts()\n      .then((r) => setPosts((r.data as any) || []))\n      .catch(() => {})\n      .finally(() => setLoading(false));\n  }, [isAuthenticated]);\n\n  return (\n    <div className=\"max-w-4xl mx-auto px-4 sm:px-6 py-8\">\n      <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }}>\n        <div className=\"flex items-center gap-3 mb-6\">\n          <div\n            className=\"w-10 h-10 rounded-xl flex items-center justify-center\"\n            style={{ background: 'linear-gradient(135deg, #4F8CFF, #7B61FF)' }}\n          >\n            <BookmarkFilled style={{ color: '#fff', fontSize: 18 }} />\n          </div>\n          <div>\n            <h1 className=\"text-2xl font-black\" style={{ color: 'var(--text)' }}>Bài đã lưu</h1>\n            <p className=\"text-sm\" style={{ color: 'var(--text-muted)' }}>{posts.length} câu hỏi</p>\n          </div>\n        </div>\n\n        <div className=\"space-y-4\">\n          {loading\n            ? Array.from({ length: 3 }).map((_, i) => <PostCardSkeleton key={i} />)\n            : posts.length === 0\n            ? (\n              <div className=\"text-center py-16 rounded-2xl border\" style={{ background: 'var(--surface)', borderColor: 'var(--border)' }}>\n                <div className=\"text-5xl mb-4\">🔖</div>\n                <h3 className=\"font-bold text-lg mb-2\" style={{ color: 'var(--text)' }}>Chưa lưu bài nào</h3>\n                <p className=\"text-sm mb-4\" style={{ color: 'var(--text-muted)' }}>Lưu các câu hỏi hay để xem lại sau</p>\n                <button\n                  onClick={() => history.push('/forum')}\n                  className=\"px-6 py-2.5 rounded-xl text-white font-semibold text-sm\"\n                  style={{ background: 'linear-gradient(135deg, #4F8CFF, #7B61FF)' }}\n                >\n                  Khám phá diễn đàn\n                </button>\n              </div>\n            )\n            : posts.map((p, i) => <PostCard key={p.id} post={p} index={i} />)\n          }\n        </div>\n      </motion.div>\n    </div>\n  );\n}\n",
      "__isJSFile": true,
      "__absFile": "C:/Users/Vu Duy Khanh/BTL-WEB-main/frontend/src/pages/saved-posts.tsx"
    },
