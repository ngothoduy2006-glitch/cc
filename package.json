{
  "name": "dien-dan-hoi-dap-backend",
  "version": "1.0.0",
  "description": "Backend API cho Diễn đàn hỏi đáp sinh viên",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:all": "concurrently \"npm run dev\" \"cmd /C \"set NODE_OPTIONS=--openssl-legacy-provider && npm start --prefix frontend\"\"",
    "migrate": "node src/utils/migrate.js",
    "seed": "node src/utils/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0",
    "express": "^4.18.2",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.6.0",
    "nodemailer": "^6.9.4",
    "sequelize": "^6.33.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16"
  }
}
